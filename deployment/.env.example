# --- Mandatory Database Configuration ---
DB_KIND=postgresql
DB_USER=mcpuser
DB_PASS=mcppass
DB_URL=jdbc:postgresql://host.docker.internal:5432/mcpdb

# --- Optional MCP Tool Customization ---
# IMPORTANT: Be as precise as possible about the purpose and content of the database.
# This helps the AI agent understand how to use the tools effectively.

# Describe what kind of data the list_tables tool will reveal.
MCP_TOOL_LIST_TABLES_DESCRIPTION=List all available tables in the CRM database (e.g., customer_profiles, sales_leads, and interaction_logs).

# Describe how describe_table helps in understanding specific entities.
MCP_TOOL_DESCRIBE_TABLE_DESCRIPTION=Inspect the columns of a specific CRM table to understand data types like email addresses, transaction dates, and lead scores.

# Describe the scope of the execute_sql tool for this specific database.
MCP_TOOL_EXECUTE_SQL_DESCRIPTION=Run read-only SQL queries to answer business questions like 'What is the total lead score for the EMEA region?' or 'List top 10 customers by revenue'.
